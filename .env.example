# Copia este archivo a .env (para desarrollo local) y rellena las keys.
# En Vercel, configura estas mismas variables en:
#   Project Settings -> Environment Variables

# API key de Google Gemini (https://aistudio.google.com/apikey) — empieza por "AIza..."
GEMINI_API_KEY=

# API key de Anthropic Claude (https://console.anthropic.com/) — empieza por "sk-ant-..."
CLAUDE_API_KEY=

# Contraseña del Patrón y Ajustes (Sección 9). Vive SOLO aquí / en Vercel,
# nunca en el código del front-end. Sin ella no se puede entrar a esos tabs.
PATRON_PASSWORD=

# ─── Firebase (service account de polar-breeze) ───
# BON LEE (nunca escribe) las colecciones del ecosistema `reportes_chofer` y
# `talonario`. Define UNA de estas dos:
#   1) El JSON completo en línea (recomendado en Vercel):
# FIREBASE_SERVICE_ACCOUNT={"type":"service_account","project_id":"polar-breeze", ...}
#   2) O una ruta a un archivo .json local (recomendado en desarrollo):
# FIREBASE_SERVICE_ACCOUNT_PATH=/ruta/al/service-account.json
